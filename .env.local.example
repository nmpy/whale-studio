# ─────────────────────────────────────────────────────────────────────────────
# .env.local — シークレット値（gitignore 済み）
# このファイルは .env.local としてコピーして使ってください。
#
#   cp .env.local.example .env.local
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase Auth（本番のみ必要）────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ─── テストモード設定 ─────────────────────────────────────────────────────────
#
# TEST_MODE=true にすると、TEST_LINE_USER_ID で指定した LINE ユーザーのみ
# Webhook が反応するようになります（他のユーザーは 200 OK を返すが処理しない）。
# 検証環境でけんぴちゃんだけに反応させたいときに使います。
#
# TEST_MODE=true
# TEST_LINE_USER_ID="Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#                    ↑ けんぴちゃんの LINE userId を貼り付ける
#                      （取得方法は docs/test-oa-setup.md 参照）
