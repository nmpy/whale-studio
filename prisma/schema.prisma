generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Oa {
  id                 String             @id @default(uuid())
  title              String
  description        String?
  channelId          String             @map("channel_id")
  channelSecret      String             @map("channel_secret")
  channelAccessToken String             @map("channel_access_token")
  /// "draft" | "active" | "paused"
  publishStatus      String             @default("draft") @map("publish_status")
  /// LINE リッチメニュー ID（LINE API で作成・適用したとき保存する）
  richMenuId         String?            @map("rich_menu_id")
  /// Google Sheets スプレッドシート ID（設定時は Sheets からシナリオを読み込む）
  spreadsheetId      String?            @map("spreadsheet_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  /// LINE公式アカウントの Basic ID（例: 613zlngs）。Webhook URL の識別子として使う。
  /// channelId（数値の API 認証用）とは別物。LINE Developers「Basic information」で確認できる。
  lineOaId           String?            @unique @map("line_oa_id")
  friendAddSettings  FriendAddSettings?
  globalCommands     GlobalCommand[]
  hintLogs           HintLog[]
  invitations        Invitation[]
  onboardingEvents   OnboardingEvent[]
  richMenus          RichMenu[]
  riddles            Riddle[]           @relation("OaRiddles")
  segments           Segment[]
  snsPosts           SnsPost[]
  subscription       Subscription?
  trackings          Tracking[]
  userTrackings      UserTracking[]
  works              Work[]
  workspaceMembers   WorkspaceMember[]

  @@index([title])
  @@index([publishStatus])
  @@index([createdAt])
  @@map("oas")
}

model Work {
  id                String         @id @default(uuid())
  oaId              String         @map("oa_id")
  title             String
  description       String?
  /// "draft" | "active" | "paused"
  publishStatus     String         @default("draft") @map("publish_status")
  sortOrder         Int            @default(0) @map("sort_order")
  /// システムメッセージ（開始/エラー等）送信者として使うキャラクター（任意）
  systemCharacterId String?        @map("system_character_id")
  /// あいさつメッセージ。未開始ユーザーが話しかけたときに送信される導入文（任意）。
  /// 未設定の場合はシステムデフォルト文にフォールバックする。
  welcomeMessage    String?        @map("welcome_message")

  // ── 演出デフォルト設定（既読・typing・ローディング）──────
  /// 既読制御モード: "inherit" | "immediate" | "delayed" | "before_reply"
  readReceiptMode       String?    @map("read_receipt_mode")
  /// 既読遅延（ms）
  readDelayMs           Int?       @map("read_delay_ms")
  /// typing 風の間を有効にするか
  typingEnabled         Boolean?   @map("typing_enabled")
  /// typing 最小待機（ms）
  typingMinMs           Int?       @map("typing_min_ms")
  /// typing 最大待機（ms）
  typingMaxMs           Int?       @map("typing_max_ms")
  /// ローディングアニメーション制御
  loadingEnabled        Boolean?   @map("loading_enabled")
  /// ローディング表示閾値（ms）
  loadingThresholdMs    Int?       @map("loading_threshold_ms")
  /// ローディング最小秒数
  loadingMinSeconds     Int?       @map("loading_min_seconds")
  /// ローディング最大秒数
  loadingMaxSeconds     Int?       @map("loading_max_seconds")

  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  characters          Character[]          @relation("WorkCharacters")
  messages            Message[]
  onboardingEvents    OnboardingEvent[]
  onboardingProgress  OnboardingProgress[]
  phases              Phase[]
  riddles             Riddle[]             @relation("WorkRiddles")
  transitions         Transition[]
  userProgress        UserProgress[]
  lineDestinations    LineDestination[]
  liffPageConfig      LiffPageConfig?
  locations           Location[]
  oa                  Oa                   @relation(fields: [oaId], references: [id], onDelete: Cascade)
  systemCharacter     Character?           @relation("WorkSystemCharacter", fields: [systemCharacterId], references: [id])

  @@index([oaId])
  @@index([publishStatus])
  @@index([sortOrder])
  @@map("works")
}

model Character {
  id            String    @id @default(uuid())
  workId        String    @map("work_id")
  name          String
  /// "text" | "image"
  iconType      String    @default("text") @map("icon_type")
  iconText      String?   @map("icon_text")
  iconImageUrl  String?   @map("icon_image_url")
  iconColor     String?   @map("icon_color")
  sortOrder     Int       @default(0) @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  work          Work      @relation("WorkCharacters", fields: [workId], references: [id], onDelete: Cascade)
  messages      Message[]
  worksAsSystem Work[]    @relation("WorkSystemCharacter")

  @@index([workId])
  @@index([name])
  @@index([sortOrder])
  @@index([isActive])
  @@map("characters")
}

model Phase {
  id              String         @id @default(uuid())
  workId          String         @map("work_id")
  /// "start" | "normal" | "ending"
  phaseType       String         @default("normal") @map("phase_type")
  name            String
  description     String?
  sortOrder       Int            @default(0) @map("sort_order")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  /// 開始トリガーキーワード（未開始ユーザーがこのキーワードを送信するとシナリオ開始）
  /// phaseType="start" のフェーズのみ有効。
  startTrigger    String?        @map("start_trigger")
  /// 再開時に送るあらすじテキスト（nullable）。
  /// 途中離脱ユーザーが「途中から再開する」を選んだとき、フェーズ先頭メッセージの前に送信される。
  resumeSummary   String?        @map("resume_summary")
  puzzleNextFor   Message[]      @relation("MessageCorrectNextPhase")
  messages        Message[]
  work            Work           @relation(fields: [workId], references: [id], onDelete: Cascade)
  transitionsFrom Transition[]   @relation("TransitionFrom")
  transitionsTo   Transition[]   @relation("TransitionTo")
  userProgress    UserProgress[]

  @@index([workId])
  @@index([phaseType])
  @@index([name])
  @@index([sortOrder])
  @@index([isActive])
  @@map("phases")
}

model Transition {
  id            String   @id @default(uuid())
  workId        String   @map("work_id")
  fromPhaseId   String   @map("from_phase_id")
  toPhaseId     String   @map("to_phase_id")
  /// ユーザーに表示される選択肢ラベル（例: 「右の扉を開ける」）
  label         String
  /// オプション: 一致キーワードなど Bot が判定に使う条件（テキスト部分一致）
  condition     String?
  /// フラグ条件式（例: "flags.has_key == true" / "flags.score >= 10" / "!flags.used"）
  /// 空の場合は常に有効。現在のユーザーフラグがこの条件を満たす場合のみ遷移を表示・実行できる。
  flagCondition String?  @map("flag_condition")
  /// 遷移実行時に UserProgress.flags へマージする JSON オブジェクト
  /// 例: {"score": 10, "has_key": true} → 既存フラグに上書きマージされる
  setFlags      String   @default("{}") @map("set_flags")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  fromPhase     Phase    @relation("TransitionFrom", fields: [fromPhaseId], references: [id], onDelete: Cascade)
  toPhase       Phase    @relation("TransitionTo", fields: [toPhaseId], references: [id], onDelete: Cascade)
  work          Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  locations     Location[]

  @@index([workId])
  @@index([fromPhaseId])
  @@index([toPhaseId])
  @@map("transitions")
}

model UserProgress {
  id               String   @id @default(uuid())
  /// LINE ユーザー ID（本番）またはテスト用任意 ID
  lineUserId       String   @map("line_user_id")
  workId           String   @map("work_id")
  currentPhaseId   String?  @map("current_phase_id")
  reachedEnding    Boolean  @default(false) @map("reached_ending")
  /// JSON 文字列。任意フラグを保存できる（例: {"hint_used": true, "score": 10}）
  /// SQLite は JSON 型非対応のため String で保持し、アプリ層で parse/stringify する
  flags            String   @default("{}") @map("flags")
  lastInteractedAt DateTime @default(now()) @map("last_interacted_at")
  /// プレビューモード（管理者・テスターが疑似プレイする場合 true）
  isPreview        Boolean  @default(false) @map("is_preview")
  /// プレビュー実行者の Supabase userId（isPreview=true のとき格納）
  previewBy        String?  @map("preview_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  currentPhase     Phase?   @relation(fields: [currentPhaseId], references: [id])
  work             Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([lineUserId, workId])
  @@index([lineUserId])
  @@index([workId])
  @@index([lastInteractedAt])
  @@map("user_progress")
}

model Message {
  id                    String     @id @default(uuid())
  workId                String     @map("work_id")
  phaseId               String?    @map("phase_id")
  characterId           String?    @map("character_id")
  /// "text" | "image" | "riddle" | "video" | "carousel" | "voice"
  messageType           String     @default("text") @map("message_type")
  body                  String?
  assetUrl              String?    @map("asset_url")
  /// 応答キーワード（Bot がこのキーワードを受信したときに送信する）
  triggerKeyword        String?    @map("trigger_keyword")
  /// 送信対象セグメント（"all" | "not_started" | "in_progress" | "completed"）
  targetSegment         String?    @map("target_segment")
  /// 通知メッセージ（テキスト以外の種別で使用。LINE の通知欄に表示される）
  notifyText            String?    @map("notify_text")
  /// 謎 ID（messageType = "riddle" のとき参照する謎）
  riddleId              String?    @map("riddle_id")
  /// クイックリプライ設定（JSON 配列 / null = 未設定）
  /// 構造: [{ label, action, value? }]
  /// action: "text" | "url" | "next" | "hint" | "custom"
  quickReplies          String?    @map("quick_replies")
  /// Flex Message の代替テキスト（messageType = "flex" のとき使用）
  altText               String?    @map("alt_text")
  /// Flex Message の JSON ペイロード（messageType = "flex" のとき使用）
  flexPayloadJson       String?    @map("flex_payload_json")
  sortOrder             Int        @default(0) @map("sort_order")
  isActive              Boolean    @default(true) @map("is_active")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  /// メッセージ種別: "start" | "normal" | "response" | "hint"
  /// start    = 開始トリガー一致時に送信（kind="start" のメッセージのみ送信）
  /// normal   = フェーズ遷移時に通常送信
  /// response = 応答キーワード（trigger_keyword）一致時に返信
  /// hint     = ヒント用（将来拡張）
  kind                  String     @default("normal") @map("kind")
  /// 正解テキスト（kind="puzzle" のとき必須）
  answer                String?    @map("answer")
  /// 表記ゆれ許容設定（JSON配列文字列: ["exact","ignore_punctuation","normalize_width"]）
  answerMatchType       String     @default("[\"exact\"]") @map("answer_match_type")
  /// 正解時の挙動: "text" | "text_and_transition" | "transition"
  correctAction         String?    @map("correct_action")
  /// 正解後の遷移先フェーズ（correct_action が transition 系のとき必須）
  correctNextPhaseId    String?    @map("correct_next_phase_id")
  /// 正解時メッセージ（任意）
  correctText           String?    @map("correct_text")
  /// 不正解時メッセージ（任意）
  incorrectText         String?    @map("incorrect_text")
  /// ヒントテキスト（任意）
  puzzleHintText        String?    @map("puzzle_hint_text")
  /// 出題形式: "text" | "image" | "video" | "carousel"（kind="puzzle" のとき使用）
  puzzleType            String?    @map("puzzle_type")
  /// 連続送信: このメッセージの後に続けて送信するメッセージ ID（自己参照 FK / null = チェーンなし）
  nextMessageId         String?    @map("next_message_id")
  /// 不正解時クイックリプライ（JSON / QuickReplyItem[]）
  incorrectQuickReplies String?    @map("incorrect_quick_replies")
  /// 前のメッセージ送信後、この発話（メッセージ）を送るまで待機するミリ秒数。0 = 即時送信
  lagMs                 Int        @default(0) @map("lag_ms")
  /// ヒント表示モード: "always"（常時）| "on_wrong"（不正解時のみ）| "hidden"（非表示）
  hintMode              String     @default("always") @map("hint_mode")

  // ── 演出設定（既読・typing・ローディング）──────────────
  /// 既読制御モード: "inherit" | "immediate" | "delayed" | "before_reply"
  readReceiptMode       String?    @map("read_receipt_mode")
  /// 既読遅延（ms）。readReceiptMode="delayed" のとき使用
  readDelayMs           Int?       @map("read_delay_ms")
  /// typing 風の間を有効にするか
  typingEnabled         Boolean?   @map("typing_enabled")
  /// typing 最小待機（ms）
  typingMinMs           Int?       @map("typing_min_ms")
  /// typing 最大待機（ms）
  typingMaxMs           Int?       @map("typing_max_ms")
  /// ローディングアニメーション制御: true=有効 / false=無効 / null=inherit
  loadingEnabled        Boolean?   @map("loading_enabled")
  /// ローディング表示閾値（ms）
  loadingThresholdMs    Int?       @map("loading_threshold_ms")
  /// ローディング最小秒数
  loadingMinSeconds     Int?       @map("loading_min_seconds")
  /// ローディング最大秒数
  loadingMaxSeconds     Int?       @map("loading_max_seconds")

  // ── タップ遷移先（画像メッセージ等）──────────────
  /// タップ時の遷移先 destination ID（nullable — null = destination 未使用）
  tapDestinationId      String?    @map("tap_destination_id")
  /// タップ時の直接URL（destination 未使用時のフォールバック）
  tapUrl                String?    @map("tap_url")

  character             Character? @relation(fields: [characterId], references: [id])
  tapDestination        LineDestination? @relation(fields: [tapDestinationId], references: [id], onDelete: SetNull)
  correctNextPhase      Phase?     @relation("MessageCorrectNextPhase", fields: [correctNextPhaseId], references: [id])
  nextMessage           Message?   @relation("MessageChain", fields: [nextMessageId], references: [id])
  prevMessages          Message[]  @relation("MessageChain")
  phase                 Phase?     @relation(fields: [phaseId], references: [id])
  work                  Work       @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@index([phaseId])
  @@index([characterId])
  @@index([messageType])
  @@index([sortOrder])
  @@index([isActive])
  @@map("messages")
}

model FriendAddSettings {
  id            String   @id @default(uuid())
  oaId          String   @unique @map("oa_id")
  /// 管理用キャンペーン名（任意）
  campaignName  String?  @map("campaign_name")
  /// 友だち追加 URL（必須）
  addUrl        String   @map("add_url")
  /// QR コード画像 URL（任意・当面未使用）
  qrCodeUrl     String?  @map("qr_code_url")
  /// SNS シェア用 OGP 画像 URL（任意）
  shareImageUrl String?  @map("share_image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  oa            Oa       @relation(fields: [oaId], references: [id], onDelete: Cascade)

  @@map("friend_add_settings")
}

model SnsPost {
  id        String   @id @default(uuid())
  oaId      String   @map("oa_id")
  /// "x" | "instagram" | "line" | "other"
  platform  String
  text      String
  imageUrl  String?  @map("image_url")
  targetUrl String?  @map("target_url")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  oa        Oa       @relation(fields: [oaId], references: [id], onDelete: Cascade)

  @@index([oaId])
  @@index([order])
  @@map("sns_posts")
}

model RichMenu {
  id                    String         @id @default(uuid())
  oaId                  String         @map("oa_id")
  name                  String
  chatBarText           String         @default("メニュー") @map("chat_bar_text")
  /// "full" (2500×1686) | "compact" (2500×843)
  size                  String         @default("compact") @map("size")
  imageUrl              String?        @map("image_url")
  lineRichMenuId        String?        @map("line_rich_menu_id")
  /// Google Spreadsheet の richmenu_id（スプレッドシート同期時のキー）
  spreadsheetRichMenuId String?        @map("spreadsheet_richmenu_id")
  /// 表示フェーズ: "start" | "playing" | "cleared" | "none"（常時）
  visiblePhase          String?        @map("visible_phase")
  isActive              Boolean        @default(true) @map("is_active")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  areas                 RichMenuArea[]
  oa                    Oa             @relation(fields: [oaId], references: [id], onDelete: Cascade)

  @@index([oaId])
  @@index([isActive])
  @@index([spreadsheetRichMenuId])
  @@index([visiblePhase])
  @@map("rich_menus")
}

model RichMenuArea {
  id          String   @id @default(uuid())
  richMenuId  String   @map("rich_menu_id")
  x           Int      @default(0)
  y           Int      @default(0)
  width       Int      @default(833)
  height      Int      @default(843)
  /// "message" | "postback" | "uri"
  actionType  String   @default("message") @map("action_type")
  actionLabel String   @default("") @map("action_label")
  /// message type: text to send; postback displayText
  actionText  String?  @map("action_text")
  /// postback type: postback data string
  actionData  String?  @map("action_data")
  /// uri type: URL to open
  actionUri       String?          @map("action_uri")
  /// destination 参照（action_type=uri のとき、直URLの代わりに使用。null = 直URL）
  destinationId   String?          @map("destination_id")
  sortOrder       Int              @default(0) @map("sort_order")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  richMenu        RichMenu         @relation(fields: [richMenuId], references: [id], onDelete: Cascade)
  destination     LineDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  @@index([richMenuId])
  @@index([sortOrder])
  @@map("rich_menu_areas")
}

model Riddle {
  id               String    @id @default(uuid())
  oaId             String    @map("oa_id")
  title            String
  /// "text" | "image" | "video" | "carousel"
  questionType     String    @default("text") @map("question_type")
  /// テキスト問題の本文（questionType = "text" のとき使用）
  questionText     String?   @map("question_text")
  /// 画像問題の URL（questionType = "image" のとき使用）
  questionImageUrl String?   @map("question_image_url")
  /// 動画問題の URL（questionType = "video" のとき使用）
  questionVideoUrl String?   @map("question_video_url")
  /// カルーセルカード JSON 配列文字列（questionType = "carousel" のとき使用）
  /// SQLite は JSON 非対応のため String で保持する
  questionCarousel String?   @map("question_carousel")
  answerText       String    @map("answer_text")
  /// "exact" | "partial" | "case_insensitive" | "normalize_width" | "normalize_kana"
  matchCondition   String    @default("exact") @map("match_condition")
  correctMessage   String    @map("correct_message")
  wrongMessage     String    @map("wrong_message")
  /// "draft" | "published"
  status           String    @default("draft")
  /// ヒント JSON 配列（Hint[] 型）。SQLite は JSON 非対応のため String で保持する
  hints            String    @default("[]") @map("hints")
  /// デフォルト応答キャラクター（任意）
  characterId      String?   @map("character_id")
  /// 送信対象セグメント識別子（任意。未設定 = 全ユーザー対象）
  targetSegment    String?   @map("target_segment")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  /// 作品スコープ管理への移行用（任意: 未設定 = OA スコープのまま）
  workId           String?   @map("work_id")
  hintLogs         HintLog[]
  oa               Oa        @relation("OaRiddles", fields: [oaId], references: [id], onDelete: Cascade)
  work             Work?     @relation("WorkRiddles", fields: [workId], references: [id], onDelete: SetNull)

  @@index([oaId])
  @@index([workId])
  @@index([status])
  @@index([createdAt])
  @@map("riddles")
}

model Segment {
  id         String   @id @default(uuid())
  oaId       String   @map("oa_id")
  name       String
  /// "phase" | "friend_7d" | "inactive_7d"
  filterType String   @default("friend_7d") @map("filter_type")
  /// filterType = "phase" のとき対象フェーズ ID
  phaseId    String?  @map("phase_id")
  /// "active" | "inactive"
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  oa         Oa       @relation(fields: [oaId], references: [id], onDelete: Cascade)

  @@index([oaId])
  @@index([status])
  @@map("segments")
}

model Tracking {
  id            String          @id @default(uuid())
  oaId          String          @map("oa_id")
  name          String
  trackingId    String          @unique @map("tracking_id")
  targetUrl     String          @map("target_url")
  utmEnabled    Boolean         @default(true) @map("utm_enabled")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  events        TrackingEvent[]
  oa            Oa              @relation(fields: [oaId], references: [id], onDelete: Cascade)
  userTrackings UserTracking[]

  @@index([oaId])
  @@map("trackings")
}

model TrackingEvent {
  id         String   @id @default(uuid())
  trackingId String   @map("tracking_id")
  ip         String?
  userAgent  String?  @map("user_agent")
  referer    String?
  clickedAt  DateTime @default(now()) @map("clicked_at")
  tracking   Tracking @relation(fields: [trackingId], references: [trackingId], onDelete: Cascade)

  @@index([trackingId])
  @@index([clickedAt])
  @@map("tracking_events")
}

model UserTracking {
  id         String   @id @default(uuid())
  oaId       String   @map("oa_id")
  lineUserId String   @map("line_user_id")
  trackingId String   @map("tracking_id")
  createdAt  DateTime @default(now()) @map("created_at")
  oa         Oa       @relation(fields: [oaId], references: [id], onDelete: Cascade)
  tracking   Tracking @relation(fields: [trackingId], references: [trackingId], onDelete: Cascade)

  @@unique([oaId, lineUserId])
  @@index([trackingId])
  @@map("user_trackings")
}

model WorkspaceMember {
  id          String       @id @default(uuid())
  /// workspace_id は現在 Oa.id と同値（MVP）
  workspaceId String       @map("workspace_id")
  userId      String       @map("user_id")
  invitedBy   String?      @map("invited_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  /// メールアドレス（招待時・表示用に保存。Supabase Auth の email と同期する）
  email       String?
  /// 招待送信日時
  invitedAt   DateTime?    @map("invited_at")
  /// 招待承認日時（参加確定日）
  joinedAt    DateTime?    @map("joined_at")
  status      MemberStatus @default(active)
  role        MemberRole   @default(viewer)
  oa          Oa           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("workspace_members")
}

model Invitation {
  id         String     @id @default(uuid())
  oaId       String     @map("oa_id")
  /// 招待先メールアドレス
  email      String
  role       MemberRole @default(editor)
  /// URL に埋め込む一意トークン（UUID v4 推奨）
  token      String     @unique
  /// 招待送信者（Supabase Auth userId）
  invitedBy  String     @map("invited_by")
  /// トークン有効期限（デフォルト: 招待から 7 日後）
  expiresAt  DateTime   @map("expires_at")
  /// 招待承認日時（null = 未承認）
  acceptedAt DateTime?  @map("accepted_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  oa         Oa         @relation(fields: [oaId], references: [id], onDelete: Cascade)

  @@index([oaId])
  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("invitations")
}

model GlobalCommand {
  id         String   @id @default(uuid())
  oaId       String   @map("oa_id")
  keyword    String
  /// "HINT" | "RESET" | "HELP" | "REPEAT" | "CUSTOM"
  actionType String   @map("action_type")
  /// CUSTOM 用メッセージテキスト / HELP 用ガイドテキスト（任意）
  /// JSON は不要。プレーンテキストをそのまま格納。
  payload    String?
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  oa         Oa       @relation(fields: [oaId], references: [id], onDelete: Cascade)

  @@index([oaId])
  @@index([actionType])
  @@map("global_commands")
}

model HintLog {
  id          String   @id @default(uuid())
  oaId        String   @map("oa_id")
  workId      String   @map("work_id")
  phaseId     String?  @map("phase_id")
  riddleId    String   @map("riddle_id")
  lineUserId  String   @map("line_user_id")
  hintStep    Int      @map("hint_step")
  /// "hint_shown" | "quick_reply_tapped"
  eventType   String   @map("event_type")
  /// quick_reply_tapped の場合: "next_hint" | "repeat_hint" | "cancel_hint" | "custom"
  actionType  String?  @map("action_type")
  actionValue String?  @map("action_value")
  createdAt   DateTime @default(now()) @map("created_at")
  oa          Oa       @relation(fields: [oaId], references: [id], onDelete: Cascade)
  riddle      Riddle   @relation(fields: [riddleId], references: [id], onDelete: Cascade)

  @@index([oaId])
  @@index([workId])
  @@index([riddleId])
  @@index([lineUserId])
  @@map("hint_logs")
}

model AdminAnnouncement {
  id          String    @id @default(uuid())
  /// "update" | "bugfix" | "known_issue" | "info"
  type        String    @default("info")
  title       String
  body        String
  important   Boolean   @default(false)
  /// null = 下書き / non-null = 公開済み
  publishedAt DateTime? @map("published_at")
  sortOrder   Int       @default(0) @map("sort_order")
  createdBy   String    @map("created_by")
  updatedBy   String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([important])
  @@index([sortOrder])
  @@map("admin_announcements")
}

model AdminDocument {
  id          String   @id @default(uuid())
  title       String
  description String?
  /// ファイルの公開 URL（Supabase Storage など）
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  /// バイト数（任意）
  fileSize    Int?     @map("file_size")
  mimeType    String   @default("application/pdf") @map("mime_type")
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@index([sortOrder])
  @@map("admin_documents")
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  /// 操作を行ったプラットフォームオーナーの Supabase userId
  actorId    String   @map("actor_id")
  /// "create" | "update" | "delete" | "publish" | "unpublish"
  action     String
  /// "announcement" | "document" | "oa" | "member"
  resource   String
  resourceId String?  @map("resource_id")
  /// 変更前後などの補足情報（JSON 文字列、任意）
  detail     String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([resource])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

/// アプリ操作ユーザー記録
/// 認証済みで操作したユーザーを記録し、メンバー招待候補の母集団として使用する。
/// user_id は UNIQUE（最新 last_seen_at で上書きされる）。
model AppActivityLog {
  id         String   @id @default(uuid())
  /// Supabase Auth の userId
  userId     String   @unique @map("user_id")
  /// メールアドレス（Supabase Auth から取得できた場合のみ格納）
  email      String?
  /// 最終操作日時（upsert で更新）
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([lastSeenAt])
  @@map("app_activity_logs")
}

/// オンボーディング各ステップへの到達を記録するテーブル。
/// @@unique([workId, step]) により、1作品につき各ステップは初回のみ記録される。
model OnboardingEvent {
  id        String   @id @default(uuid())
  oaId      String   @map("oa_id")
  workId    String   @map("work_id")
  /// OnboardingStep 定数に対応する文字列
  step      String
  createdAt DateTime @default(now()) @map("created_at")

  oa   Oa   @relation(fields: [oaId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, step], name: "workId_step")
  @@index([oaId])
  @@index([workId])
  @@index([createdAt])
  @@map("onboarding_events")
}

/// ユーザー単位のオンボーディング進捗を記録するテーブル。
/// OnboardingEvent（作品単位）とは別に、ユーザー単位でのステップ到達を管理する。
model OnboardingProgress {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  workId          String   @map("work_id")
  step            String
  /// ステップ初回到達日時。upsert で update: {} としているため createdAt と同値になる。
  /// OnboardingEvent との統合後に集計の主軸となるフィールド。
  firstAchievedAt DateTime @default(now()) @map("first_achieved_at")
  createdAt       DateTime @default(now()) @map("created_at")
  work            Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId, step])
  @@index([userId, workId])
  @@index([step])
  @@index([workId])
  @@map("onboarding_progress")
}

/// 課金導線イベントを記録するテーブル。
/// pricing ページ到達・CTA クリック・フィードバック送信などを集計する。
model BillingEvent {
  id        String   @id @default(uuid())
  /// BillingEvent 定数に対応するイベント種別
  event     String
  /// 発火元ユーザーの Supabase Auth userId（未認証の場合は null）
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@map("billing_events")
}

/// 課金導線イベントの詳細ログ。
/// BillingEvent（集計用）とは別に、コンテキスト情報（oa_id / work_id / source）を
/// 保持する詳細ログテーブル。将来的なコホート分析・ユーザー単位の追跡に使用する。
model BillingEventLog {
  id        String   @id @default(uuid())
  /// Supabase Auth の userId（未ログイン時は null）
  userId    String?  @map("user_id")
  /// イベント発生時に参照していた OA（null = OA コンテキスト外）
  oaId      String?  @map("oa_id")
  /// イベント発生時に参照していた作品（null = 作品コンテキスト外）
  workId    String?  @map("work_id")
  /// BillingEvent 定数に対応するイベント種別
  event     String
  /// pricing への流入元・補助情報（例: "header" / "banner" / "gate" / "preview"）
  source    String?
  /// 遷移元プラン名（例: "tester"）。null = コンテキスト不明
  fromPlan  String?  @map("from_plan")
  /// 遷移先プラン名（例: "editor"）。null = コンテキスト不明
  toPlan    String?  @map("to_plan")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@map("billing_event_logs")
}

/// ユーザー行動・エラー・成功イベントの汎用ログ。
/// billing_event_logs より広いスコープで行動追跡に使用する。
/// payload は JSON 文字列でイベント種別ごとの補足情報を格納する。
model EventLog {
  id        String   @id @default(uuid())
  /// Supabase Auth の userId（未認証時は null）
  userId    String?  @map("user_id")
  /// イベント発生時に参照していた OA（null = コンテキスト外）
  oaId      String?  @map("oa_id")
  /// イベント名（例: "screen_view" / "flow_step" / "error"）
  eventName String   @map("event_name")
  /// イベント種別ごとの補足情報 JSON 文字列（例: {"page":"/pricing","source":"header"}）
  payload   String   @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([eventName])
  @@index([oaId])
  @@index([createdAt])
  @@map("event_logs")
}

/// プラン定義テーブル。各プランの上限・価格を管理する。
/// MVP では tester / editor の 2 プランのみ。enterprise は将来拡張。
model Plan {
  id            String         @id @default(uuid())
  /// プランキー（例: "tester" | "editor" | "enterprise"）
  name          String         @unique
  /// 表示名（例: "テスタープラン"）
  displayName   String         @map("display_name")
  /// 同時に所有できる作品数の上限（-1 = 無制限）
  maxWorks      Int            @default(1) @map("max_works")
  /// 月あたりのプレイヤー上限（-1 = 無制限）
  maxPlayers    Int            @default(-1) @map("max_players")
  /// 月額料金（円）。0 = 無料
  priceMonthly  Int            @default(0) @map("price_monthly")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  subscriptions Subscription[]

  @@index([name])
  @@index([isActive])
  @@map("plans")
}

/// OA 単位のサブスクリプション。1 OA につき 1 レコード（@@unique(oaId)）。
/// status: "active" | "trialing" | "canceled" | "past_due"
model Subscription {
  id                 String    @id @default(uuid())
  oaId               String    @unique @map("oa_id")
  planId             String    @map("plan_id")
  /// "active" | "trialing" | "canceled" | "past_due"
  status             String    @default("trialing")
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  canceledAt         DateTime? @map("canceled_at")
  /// 外部決済システムのサブスクリプション ID（Stripe 等。MVP では未使用 = null）
  externalId         String?   @map("external_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  oa                 Oa        @relation(fields: [oaId], references: [id], onDelete: Cascade)
  plan               Plan      @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

// ────────────────────────────────────────────────
// LineDestination — 再利用可能な遷移先URL定義
// ────────────────────────────────────────────────

model LineDestination {
  id                String   @id @default(uuid())
  workId            String   @map("work_id")
  /// プログラム参照用キー（英数字・ハイフン・アンダースコア）。work 内で unique
  key               String
  /// 管理画面上の表示名
  name              String
  description       String?
  /// "liff" | "internal_url" | "external_url"
  destinationType   String   @map("destination_type")
  /// destination_type=liff のとき有効: "work_main" | "custom"
  liffTargetType    String?  @map("liff_target_type")
  /// 遷移先URLまたはパス
  urlOrPath         String?  @map("url_or_path")
  /// 追加クエリパラメータ（JSONB）
  queryParamsJson   Json     @default("{}") @map("query_params_json") @db.JsonB
  isEnabled         Boolean  @default(true) @map("is_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  work              Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  /// この destination を参照しているメッセージ（逆参照）
  messages          Message[]
  /// この destination を参照しているリッチメニューエリア（逆参照）
  richMenuAreas     RichMenuArea[]

  @@unique([workId, key])
  @@index([workId])
  @@index([destinationType])
  @@index([isEnabled])
  @@map("line_destinations")
}

// ────────────────────────────────────────────────
// Location — ビーコン / QR チェックインポイント
// ────────────────────────────────────────────────

model Location {
  id              String          @id @default(uuid())
  workId          String          @map("work_id")
  name            String
  description     String?
  /// Bluetooth ビーコン UUID（任意 — 未設定時は QR コードのみ）
  beaconUuid      String?         @map("beacon_uuid")
  beaconMajor     Int?            @map("beacon_major")
  beaconMinor     Int?            @map("beacon_minor")
  /// GPS チェックイン: 緯度
  latitude        Float?
  /// GPS チェックイン: 経度
  longitude       Float?
  /// GPS チェックイン: 許容半径（メートル）
  radiusMeters    Int?            @map("radius_meters")
  /// @deprecated checkinMode から導出される。将来削除予定。
  /// 削除条件: (1) API レスポンスから gps_enabled を除外 (2) 旧クライアント互換が不要
  /// 現在は checkinMode 保存時に deriveGpsEnabled() で自動同期される。
  gpsEnabled      Boolean         @default(false) @map("gps_enabled")
  /// チェックイン方式: "qr_only" | "gps_only" | "qr_and_gps"
  checkinMode     String          @default("qr_only") @map("checkin_mode")
  /// チェックインのクールダウン秒数（同一ユーザー×同一ロケーション）。デフォルト 300 = 5分
  cooldownSeconds Int             @default(300) @map("cooldown_seconds")
  /// チェックイン時に自動発火する遷移（任意）
  transitionId    String?         @map("transition_id")
  /// チェックイン時に UserProgress.flags へマージする JSON オブジェクト
  setFlags        String          @default("{}") @map("set_flags")
  sortOrder       Int             @default(0) @map("sort_order")
  isActive        Boolean         @default(true) @map("is_active")
  /// スタンプラリー: この地点をスタンプ対象にするか
  stampEnabled    Boolean         @default(true) @map("stamp_enabled")
  /// スタンプ表示名（未設定なら name を使用）
  stampLabel      String?         @map("stamp_label")
  /// スタンプ並び順
  stampOrder      Int?            @map("stamp_order")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  work            Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  transition      Transition?     @relation(fields: [transitionId], references: [id], onDelete: SetNull)
  visits          LocationVisit[]

  @@index([workId])
  @@index([beaconUuid, beaconMajor, beaconMinor])
  @@index([isActive])
  @@map("locations")
}

model LocationVisit {
  id              String   @id @default(uuid())
  lineUserId      String   @map("line_user_id")
  locationId      String   @map("location_id")
  workId          String   @map("work_id")
  /// チェックイン方式: "qr" | "gps" | "beacon"
  checkinMethod   String   @default("qr") @map("checkin_method")
  /// GPS チェックイン時の実測距離（メートル）
  distanceMeters  Float?   @map("distance_meters")
  visitedAt       DateTime @default(now()) @map("visited_at")
  location        Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([lineUserId, locationId])
  @@index([workId])
  @@index([visitedAt])
  @@map("location_visits")
}

/// GPS チェックイン試行ログ（成功・失敗問わず記録）
/// LocationVisit は成功時のみ。このテーブルは全試行を記録し、成功率分析に使う。
model CheckinAttempt {
  id             String   @id @default(uuid())
  workId         String   @map("work_id")
  locationId     String   @map("location_id")
  lineUserId     String   @map("line_user_id")
  /// チェックイン方式: "gps" | "beacon" など（QR は試行ログ不要のため基本 GPS のみ）
  method         String   @default("gps")
  /// "success" | "out_of_range" | "permission_denied" | "gps_unavailable"
  /// | "location_not_supported" | "location_config_incomplete" | "invalid_request"
  status         String
  /// 失敗理由の補足（任意）
  failureReason  String?  @map("failure_reason")
  /// サーバー計算の距離（メートル）
  distanceMeters Float?   @map("distance_meters")
  /// クライアント送信の緯度
  lat            Float?
  /// クライアント送信の経度
  lng            Float?
  createdAt      DateTime @default(now()) @map("created_at")

  // dedupe 用: hasDuplicateAttempt() の WHERE 句に最適化
  @@index([workId, locationId, lineUserId, status, createdAt])
  // retention cleanup 用: cleanupOldAttempts() の WHERE createdAt < cutoff
  @@index([createdAt])
  // work/location 単位の集計用 (Audience stats)
  @@index([workId, status])
  @@map("checkin_attempts")
}

// ────────────────────────────────────────────────
// LIFF ページ設定
// ────────────────────────────────────────────────

model LiffPageConfig {
  id          String          @id @default(uuid())
  workId      String          @unique @map("work_id")
  isEnabled   Boolean         @default(false) @map("is_enabled")
  title       String?
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  blocks      LiffPageBlock[]
  work        Work            @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@map("liff_page_configs")
}

model LiffPageBlock {
  id                      String         @id @default(uuid())
  pageConfigId            String         @map("page_config_id")
  /// "free_text" | "start_button" | "resume_button" | "progress" | "evidence_list" | "hint_list" | "character_list" | "image" | "video"
  blockType               String         @map("block_type")
  sortOrder               Int            @default(0) @map("sort_order")
  isEnabled               Boolean        @default(true) @map("is_enabled")
  title                   String?
  /// ブロック固有の設定（JSON）
  settingsJson            Json           @default("{}") @map("settings_json") @db.JsonB
  /// 表示条件（"always" | "before_start" | "in_progress" | "completed"）
  visibilityConditionJson String?        @map("visibility_condition_json")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")
  pageConfig              LiffPageConfig @relation(fields: [pageConfigId], references: [id], onDelete: Cascade)

  @@index([pageConfigId])
  @@index([sortOrder])
  @@index([blockType])
  @@map("liff_page_blocks")
}

/// メンバーロール（権限階層: owner > admin > editor > tester > viewer）
/// tester: 課金前ユーザー向け体験ロール。コンテンツ作成・編集のみ可能。
enum MemberRole {
  owner
  admin
  editor
  tester
  viewer
}

/// メンバーステータス
enum MemberStatus {
  active
  inactive
  suspended
}

/// ユーザープロフィール（Supabase Auth ユーザーと 1:1）
model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  username  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}
