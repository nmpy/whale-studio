# ─── データベース ───────────────────────────────────
# ローカル開発用 SQLite（PostgreSQL 不要）
# このファイルは安全な値のみ含むためコミット可能です。
DATABASE_URL="file:./dev.db"

# ─── Supabase Auth ──────────────────────────────────
# 本番のみ必要。シークレットを含む場合は .env.local に書いてください（gitignore済み）。
# NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
