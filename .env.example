# ─── データベース ───────────────────────────────────
# ローカル開発（デフォルト）: SQLite ファイルを使用
# ファイルは prisma/dev.db に自動生成されます。PostgreSQL 不要！
DATABASE_URL="file:./dev.db"

# 本番環境（PostgreSQL）に切り替える場合は以下をコメント解除して設定してください:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# ※ その場合は prisma/schema.prisma の provider も "postgresql" に戻してください。

# ─── Supabase Auth ──────────────────────────────────
# 本番のみ必要。ローカル開発では空欄のままで OK（認証スタブが自動で有効になります）
# NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ─── テストユーザー限定モード ───────────────────────
# 開発中に特定の LINE ユーザー ID からのイベントのみ処理したい場合に使用します。
# 設定した userId 以外のイベントは無視され、返信・DB 更新は行われません。
#
# 使い方:
#   1. TEST_MODE=true に設定する
#   2. TEST_LINE_USER_ID に自分の LINE userId を設定する
#      （userId は開発サーバーのログ "[Webhook] text message userId=Uxxxxxx" で確認できます）
#   3. .env.local に記載して開発サーバーを再起動する
#
# 無効化:
#   TEST_MODE=false にするか、この 2 行をコメントアウト / 削除する
#   本番環境では設定しないこと（全ユーザーが処理されなくなります）
TEST_MODE=false
TEST_LINE_USER_ID=

# ─── フィードバック送信（Google Apps Script）────────
# ヘッダーの「フィードバック」ボタンから送信されたデータの書き込み先。
# Google Apps Script の Web App URL を設定してください。
# 未設定の場合はサーバーコンソールにログ出力されます（開発時の動作確認用）。
#
# スプレッドシート シート名: feedback
# ヘッダー列順:
#   id | created_at | user_name | user_email | page_name | page_url |
#   oa_id | oa_name | work_id | work_name | category | content |
#   status | memo | user_agent
#
# GAS スクリプト例（doPost 関数）:
#   function doPost(e) {
#     const d = JSON.parse(e.postData.contents);
#     SpreadsheetApp.getActiveSpreadsheet()
#       .getSheetByName("feedback")
#       .appendRow([
#         d.id, d.created_at, d.user_name, d.user_email,
#         d.page_name, d.page_url,
#         d.oa_id, d.oa_name, d.work_id, d.work_name,
#         d.category, d.content,
#         d.status, d.memo, d.user_agent,
#       ]);
#     return ContentService
#       .createTextOutput(JSON.stringify({ ok: true }))
#       .setMimeType(ContentService.MimeType.JSON);
#   }
#
# GAS_FEEDBACK_WEBHOOK_URL="https://script.google.com/macros/s/XXXXXXXXXX/exec"

# ─── LINE 既読制御 & ローディングアニメーション ──────
# Webhook のメッセージイベントで即既読にせず、指定ミリ秒後に既読を送る。
# 返信処理が先に完了した場合は返信直前に既読を送信する。
#
# READ_RECEIPT_ENABLED   — 既読遅延制御を有効にする（"false" で無効。デフォルト: true）
# READ_DELAY_MS          — 既読を遅延する時間（ms）。デフォルト: 2000、上限: 10000
# LOADING_ANIMATION_ENABLED — ローディングアニメーション表示の有効化（デフォルト: true）
# LOADING_THRESHOLD_MS   — 処理時間がこの閾値を超えたらローディング表示（ms）。デフォルト: 3000
# LOADING_SECONDS        — ローディング表示秒数（5〜60）。デフォルト: 10
#
# READ_RECEIPT_ENABLED=true
# READ_DELAY_MS=2000
# LOADING_ANIMATION_ENABLED=true
# LOADING_THRESHOLD_MS=3000
#
# ローディング秒数（可変）:
#   LOADING_SECONDS_MIN — 最小秒数（デフォルト: 5）
#   LOADING_SECONDS_MAX — 最大秒数（デフォルト: 15）
#   経過時間から自然な秒数を自動算出し min〜max にクランプする。
#   返信到着でローディングは自動的に消える（満了を待たない）。
# LOADING_SECONDS_MIN=5
# LOADING_SECONDS_MAX=15
#
# typing 風待機（返信前の「考えている風の間」）:
#   TYPING_ENABLED       — "true" で有効（デフォルト: false = OFF）
#   TYPING_MIN_MS        — 最小待機（ms）。デフォルト: 300
#   TYPING_MAX_MS        — 最大待機（ms）。デフォルト: 1200
#   ※ 全体処理が loadingThresholdMs を超えている場合は自動スキップ
# TYPING_ENABLED=false
# TYPING_MIN_MS=300
# TYPING_MAX_MS=1200
#
# テキスト長に応じた動的既読遅延（READ_DELAY_MS より優先）
# 書式: "最大文字数:遅延ms,最大文字数:遅延ms,*:遅延ms"
# 例: 10文字未満→1秒、50文字未満→2秒、それ以上→3秒
# READ_DELAY_TIERS="10:1000,50:2000,*:3000"

# ─── 開発メモ ───────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL が未設定の場合、
# NODE_ENV=development では認証スタブ（dev-user）が自動で有効になります。
# 本番環境では必ず Supabase の値を設定してください。
