@@ -0,0 +1,143 @@
+/**
+ * checkPuzzleAnswer ユニットテスト
+ *
+ * webhook/route.ts と runtime/advance/route.ts の両方で使われている
+ * パズル回答照合ロジックのテスト。
+ * ここでは同一ロジックを再現し、各 matchType の動作を検証する。
+ */
+import { describe, it, expect } from "vitest";
+
+// ── ロジック再現（webhook/route.ts と同一） ─────────────────
+
+function normKw(s: string): string {
+  return s.trim().normalize("NFKC");
+}
+
+function removePunct(s: string): string {
+  return s.replace(/[!?,.　\u0020\t、。，．・：；！？…‥〜ー\u3000-\u303F]+/gu, "").trim();
+}
+
+function checkPuzzleAnswer(
+  input: string,
+  answer: string,
+  matchTypes: string[],
+): boolean {
+  const inputNorm = normKw(input);
+  const answerNorm = normKw(answer);
+
+  // 空文字の正解は常に不正解とする（partial で常時 true になるのを防ぐ）
+  if (answerNorm === "") return false;
+
+  for (const mt of matchTypes) {
+    if (mt === "exact" || mt === "normalize_width") {
+      if (inputNorm === answerNorm) return true;
+    }
+    if (mt === "partial") {
+      if (inputNorm.includes(answerNorm)) return true;
+    }
+    if (mt === "ignore_punctuation") {
+      if (removePunct(inputNorm) === removePunct(answerNorm)) return true;
+    }
+  }
+  return false;
+}
+
+// ── テスト ─────────────────────────────────────────────────
+
+describe("checkPuzzleAnswer", () => {
+  // ── exact ────────────────────────────────────────────────
+  describe("exact マッチ", () => {
+    it("完全一致で正解", () => {
+      expect(checkPuzzleAnswer("りんご", "りんご", ["exact"])).toBe(true);
+    });
+
+    it("不一致で不正解", () => {
+      expect(checkPuzzleAnswer("みかん", "りんご", ["exact"])).toBe(false);
+    });
+
+    it("部分一致テキストでは exact 不正解", () => {
+      expect(checkPuzzleAnswer("答えはりんごです", "りんご", ["exact"])).toBe(false);
+    });
+
+    it("前後空白は trim されて一致", () => {
+      expect(checkPuzzleAnswer("  りんご  ", "りんご", ["exact"])).toBe(true);
+    });
+
+    it("NFKC 正規化で全角→半角が吸収される", () => {
+      expect(checkPuzzleAnswer("ＡＢＣ", "ABC", ["exact"])).toBe(true);
+    });
+  });
+
+  // ── partial ──────────────────────────────────────────────
+  describe("partial マッチ（部分一致）", () => {
+    it("完全一致でも正解", () => {
+      expect(checkPuzzleAnswer("りんご", "りんご", ["partial"])).toBe(true);
+    });
+
+    it("入力文中に正解が含まれていれば正解", () => {
+      expect(checkPuzzleAnswer("答えはりんごです", "りんご", ["partial"])).toBe(true);
+    });
+
+    it("正解が先頭にあっても正解", () => {
+      expect(checkPuzzleAnswer("りんごかな？", "りんご", ["partial"])).toBe(true);
+    });
+
+    it("正解の前に文字があっても正解（青りんご）", () => {
+      expect(checkPuzzleAnswer("青りんご", "りんご", ["partial"])).toBe(true);
+    });
+
+    it("正解が含まれていなければ不正解", () => {
+      expect(checkPuzzleAnswer("みかん", "りんご", ["partial"])).toBe(false);
+    });
+
+    it("NFKC 正規化後に部分一致判定される", () => {
+      // 全角 "ＡＢＣ" は NFKC で "ABC" に正規化される
+      expect(checkPuzzleAnswer("答えはＡＢＣです", "ABC", ["partial"])).toBe(true);
+    });
+
+    it("前後空白が trim された後に判定される", () => {
+      expect(checkPuzzleAnswer("  答えはりんごです  ", "りんご", ["partial"])).toBe(true);
+    });
+  });
+
+  // ── 空文字ガード ─────────────────────────────────────────
+  describe("空文字ガード", () => {
+    it("正解が空文字のとき partial でも false", () => {
+      expect(checkPuzzleAnswer("なんでも", "", ["partial"])).toBe(false);
+    });
+
+    it("正解が空白のみのとき partial でも false", () => {
+      expect(checkPuzzleAnswer("なんでも", "   ", ["partial"])).toBe(false);
+    });
+
+    it("正解が空文字のとき exact でも false", () => {
+      expect(checkPuzzleAnswer("", "", ["exact"])).toBe(false);
+    });
+  });
+
+  // ── ignore_punctuation ────────────────────────────────────
+  describe("ignore_punctuation マッチ", () => {
+    it("句読点なしで一致", () => {
+      expect(checkPuzzleAnswer("りんご", "りんご", ["ignore_punctuation"])).toBe(true);
+    });
+
+    it("句読点の有無を吸収", () => {
+      expect(checkPuzzleAnswer("りんご。", "りんご", ["ignore_punctuation"])).toBe(true);
+    });
+
+    it("内容が異なれば不正解", () => {
+      expect(checkPuzzleAnswer("みかん", "りんご", ["ignore_punctuation"])).toBe(false);
+    });
+  });
+
+  // ── 複数 matchTypes ──────────────────────────────────────
+  describe("複数 matchTypes 組み合わせ", () => {
+    it("exact で不正解でも partial で正解なら true", () => {
+      expect(checkPuzzleAnswer("答えはりんごです", "りんご", ["exact", "partial"])).toBe(true);
+    });
+
+    it("どの matchType にも該当しなければ false", () => {
+      expect(checkPuzzleAnswer("みかん", "りんご", ["exact", "partial"])).toBe(false);
+    });
+  });
+});
