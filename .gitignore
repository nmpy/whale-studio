# ── 依存 ──────────────────────────────────────
node_modules/

# ── Next.js ───────────────────────────────────
.next/
out/

# ── 環境変数 ──────────────────────────────────────────
# .env         → ローカル開発用デフォルト値（SQLite URL のみ）。コミット可。
# .env.local   → 本番シークレット（Supabase キーなど）。必ずGit管理外に。
.env.local
.env.*.local
# ※ .env は file:./dev.db のみを含む安全なファイルなのでコミット対象です。

# ── SQLite DBファイル（ローカル開発用） ─────────
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm

# ── Prisma ────────────────────────────────────
# generated client は npm install 後に生成されるためトラッキング不要
# node_modules/@prisma/ は上記 node_modules/ で除外済み

# ── OS / エディタ ─────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ── ビルド成果物 ──────────────────────────────
dist/
build/
.vercel
